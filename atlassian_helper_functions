def api_request(
    method: str,
    url: str,
    params: Optional[Dict[str, Any]] = None,
    json_body: Optional[Dict[str, Any]] = None,
    timeout: int = REQUEST_TIMEOUT_SECS
) -> Dict[str, Any]:
    for attempt in range(1, MAX_RETRIES + 1):
        response = SESSION.request(
            method=method,
            url=url,
            params=params,
            json=json_body,
            timeout=timeout
        )

        if response.status_code in (200, 201):
            return response.json()

        if response.status_code == 204:
            return {}

        if response.status_code == 429:
            retry_after = response.headers.get("Retry-After")
            sleep_secs = int(retry_after) if retry_after and retry_after.isdigit() else SLEEP_SECS_ON_429
            print(f"Rate limited. Sleeping {sleep_secs} seconds. Attempt {attempt}/{MAX_RETRIES}")
            time.sleep(sleep_secs)
            continue

        if 500 <= response.status_code < 600 and attempt < MAX_RETRIES:
            wait = min(2 ** attempt, 30)
            print(f"Server error {response.status_code}. Retrying in {wait} seconds. Attempt {attempt}/{MAX_RETRIES}")
            time.sleep(wait)
            continue

        raise RuntimeError(
            f"API request failed.\n"
            f"Method: {method}\n"
            f"URL: {url}\n"
            f"Status: {response.status_code}\n"
            f"Response: {response.text}"
        )

    raise RuntimeError(f"API request failed after {MAX_RETRIES} retries: {method} {url}")

