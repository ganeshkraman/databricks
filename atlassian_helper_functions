def get_users_by_group_id(directory_id: str, group_id: str) -> List[Dict[str, Any]]:
    url = f"{BASE_URL}/v2/orgs/{ORG_ID}/directories/{directory_id}/users"
    params = {
        "limit": PAGE_SIZE,
        "groupIds": [group_id]
    }
    return paginate_get(url, params=params)

