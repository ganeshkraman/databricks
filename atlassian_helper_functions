def get_users_by_resource_ids(directory_id: str, resource_ids: List[str]) -> List[Dict[str, Any]]:
    if not resource_ids:
        return []

    url = f"{BASE_URL}/v2/orgs/{ORG_ID}/directories/{directory_id}/users"
    params = {
        "limit": PAGE_SIZE,
        "resourceIds": resource_ids
    }
    return paginate_get(url, params=params)

