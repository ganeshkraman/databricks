def flatten_user_rows(rows: List[Dict[str, Any]], product_name: str) -> List[Dict[str, Any]]:
    out = []
    for r in rows:
        out.append({
            "product_name": product_name,
            "directory_id": r.get("directory_id"),
            "account_id": r.get("accountId"),
            "account_type": r.get("accountType"),
            "account_status": r.get("accountStatus"),
            "claim_status": r.get("claimStatus"),
            "status": r.get("status"),
            "name": r.get("name"),
            "email": r.get("email"),
            "nickname": r.get("nickname"),
            "platform_roles": json.dumps(r.get("platformRoles", [])),
            "raw_json": json.dumps(r)
        })
    return out

