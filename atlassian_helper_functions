def paginate_get(url: str, params: Optional[Dict[str, Any]] = None, data_key: str = "data") -> List[Dict[str, Any]]:
    all_rows: List[Dict[str, Any]] = []
    current_params = dict(params or {})
    current_params.setdefault("limit", PAGE_SIZE)

    while True:
        payload = api_request("GET", url, params=current_params)
        rows = payload.get(data_key, [])
        all_rows.extend(rows)

        links = payload.get("links", {}) or {}
        next_cursor = links.get("next")

        if not next_cursor:
            break

        current_params["cursor"] = next_cursor

    return all_rows

# COMMAND ----------

def paginate_post(url: str, json_body: Optional[Dict[str, Any]] = None, data_key: str = "data") -> List[Dict[str, Any]]:
    all_rows: List[Dict[str, Any]] = []
    body = dict(json_body or {})
    body.setdefault("limit", PAGE_SIZE)

    while True:
        payload = api_request("POST", url, json_body=body)
        rows = payload.get(data_key, [])
        all_rows.extend(rows)

        links = payload.get("links", {}) or {}
        next_cursor = links.get("next")

        if not next_cursor:
            break

        body["cursor"] = next_cursor

    return all_rows

