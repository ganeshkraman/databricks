# COMMAND ----------
# Databricks notebook: Create / Update All-Purpose Cluster Policy with Tags

import requests
import json

# COMMAND ----------
# 1. Get workspace URL and token from notebook context

workspace_url = dbutils.notebook.entry_point.getDbutils() \
    .notebook() \
    .getContext() \
    .apiUrl() \
    .get()

token = dbutils.notebook.entry_point.getDbutils() \
    .notebook() \
    .getContext() \
    .apiToken() \
    .get()

headers = {
    "Authorization": f"Bearer {token}",
    "Content-Type": "application/json"
}

# COMMAND ----------
# 2. Define policy name

policy_name = "gda-us-dev-allpurpose-finops-v1"

# COMMAND ----------
# 3. Define cluster policy JSON
# This is for all-purpose compute with mandatory cost tags.

policy_definition = {
    "cluster_type": {
        "type": "fixed",
        "value": "all-purpose"
    },

    "custom_tags.env": {
        "type": "fixed",
        "value": "DEV",
        "hidden": False
    },

    "custom_tags.business": {
        "type": "enum",
        "values": [
            "commercial",
            "clinical",
            "discovery",
            "corporate"
        ],
        "defaultValue": "commercial"
    },

    "custom_tags.program": {
        "type": "unlimited",
        "isOptional": False
    },

    "custom_tags.workload_type": {
        "type": "enum",
        "values": [
            "adhoc",
            "etl",
            "bi",
            "ml",
            "app"
        ],
        "defaultValue": "adhoc"
    },

    "custom_tags.owner": {
        "type": "unlimited",
        "isOptional": False
    },

    "autotermination_minutes": {
        "type": "fixed",
        "value": 30,
        "hidden": False
    },

    "autoscale.min_workers": {
        "type": "fixed",
        "value": 1
    },

    "autoscale.max_workers": {
        "type": "range",
        "minValue": 1,
        "maxValue": 4,
        "defaultValue": 2
    }
}

# COMMAND ----------
# 4. Check if policy already exists

list_url = f"{workspace_url}/api/2.0/policies/clusters/list"

response = requests.get(list_url, headers=headers)
response.raise_for_status()

policies = response.json().get("policies", [])

existing_policy = next(
    (p for p in policies if p.get("name") == policy_name),
    None
)

existing_policy

# COMMAND ----------
# 5. Create or update policy

policy_payload = {
    "name": policy_name,
    "definition": json.dumps(policy_definition),
    "description": "All-purpose compute policy for FinOps tagging and cost visibility. Enforces env, business, program, workload_type, and owner tags."
}

if existing_policy:
    policy_id = existing_policy["policy_id"]

    edit_url = f"{workspace_url}/api/2.0/policies/clusters/edit"

    policy_payload["policy_id"] = policy_id

    result = requests.post(edit_url, headers=headers, json=policy_payload)
    result.raise_for_status()

    print(f"Updated existing cluster policy: {policy_name}")
    print(f"Policy ID: {policy_id}")

else:
    create_url = f"{workspace_url}/api/2.0/policies/clusters/create"

    result = requests.post(create_url, headers=headers, json=policy_payload)
    result.raise_for_status()

    policy_id = result.json().get("policy_id")

    print(f"Created new cluster policy: {policy_name}")
    print(f"Policy ID: {policy_id}")

# COMMAND ----------
# 6. Validate policy

get_url = f"{workspace_url}/api/2.0/policies/clusters/get"

response = requests.get(
    get_url,
    headers=headers,
    params={"policy_id": policy_id}
)

response.raise_for_status()

created_policy = response.json()

print(json.dumps(created_policy, indent=2))
